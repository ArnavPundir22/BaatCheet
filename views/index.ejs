<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, interactive-widget=resizes-content">
    <title>BaatCheet | Ephemeral Chat</title>
    <link rel="stylesheet" href="/static/css/style.css?v=14">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/static/icon.svg">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#6366f1">
</head>

<body>
    <!-- Cinematic Overlay -->
    <div id="cinematic-overlay">
        <div id="cinematic-canvas-container"></div>
        <div class="cinematic-hud" id="cinematic-hud-booting">
            <div class="glitch-spinner" style="margin-bottom: 20px;"></div>
            <h2 class="font-mono">[SYS.INIT] > BOOTING ENVIRONMENT...</h2>
            <p class="font-mono" style="color: var(--primary);">Establishing secure connection.</p>
        </div>
        <div class="cinematic-hud" id="cinematic-hud-welcome" style="display: none; opacity: 0; transform: scale(0.9); transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);">
            <h1 class="logo-title cinematic-title" style="font-size: clamp(3rem, 15vw, 6rem);">BaatCheet</h1>
            <p class="font-mono" style="letter-spacing: 5px; color: var(--secondary);">ACCESS GRANTED</p>
        </div>
    </div>

    <div class="wireframe-grid"></div>
    <div id="home-3d-canvas-container" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; pointer-events: none;"></div>

    <div class="container index-container" style="max-width: 1200px; padding: 4rem 2rem; display: block;">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h1 class="logo-title"
                style="font-size: clamp(2.5rem, 12vw, 5rem); margin-bottom: 0;">
                BaatCheet</h1>
            <p class="subtitle font-mono"
                style="letter-spacing: 1px; font-size: clamp(0.75rem, 3vw, 1rem); text-transform: uppercase; margin-top: 10px;">
                INTEGRATED EPHEMERAL COMMUNICATION SYSTEM</p>
        </div>

        <% if (error) { %>
        <div class="error-msg font-mono" style="margin-bottom: 2rem;"><%= error %></div>
        <% } %>

        <div class="bento-section">
            <!-- Room Creation (Spans 2 columns on desktop) -->
            <div class="card--border-glow col-span-2">
                <h3 class="font-mono" style="color: var(--primary); margoin-bottom: 1rem;">[SYS.INIT] > New Session</h3>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Initialize a fresh, secure, disposable
                    environment.</p>
                <form action="/" method="POST">
                    <div class="input-group">
                        <label for="username" class="font-mono">User Identity</label>
                        <input type="text" id="username" name="username" placeholder="Enter operator alias" required
                            autocomplete="off">
                    </div>
                    <div class="input-group">
                        <label for="room_name" class="font-mono">Environment Designation (Optional)</label>
                        <input type="text" name="room_name" placeholder="Assign room title" autocomplete="off">
                    </div>
                    <button type="submit" name="action" value="create" class="btn btn-primary font-mono"
                        style="text-transform: uppercase;">Execute: Create Room</button>
                </form>
            </div>

            <!-- Join Room -->
            <div class="card--border-glow col-span-2">
                <h3 class="font-mono" style="color: var(--secondary); margin-bottom: 1rem;">[SYS.CONNECT] > Existing
                    Session</h3>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Establish connection to an active
                    environment.</p>
                <form action="/" method="POST">
                    <div class="input-group">
                        <label for="join_username" class="font-mono">User Identity</label>
                        <input type="text" id="join_username" name="username" placeholder="Enter operator alias"
                            required autocomplete="off">
                    </div>
                    <div class="input-group">
                        <label for="room_code" class="font-mono">Connection Token</label>
                        <input type="text" name="room_code" placeholder="e.g. A7X9Q2" required autocomplete="off">
                    </div>
                    <button type="submit" name="action" value="join" class="btn btn-primary font-mono"
                        style="text-transform: uppercase;">Execute: Join Room</button>
                </form>
            </div>

            <!-- Zero-Log Stats -->
            <div class="card--border-glow col-span-2" style="background: rgba(16, 185, 129, 0.05);">
                <h3 class="font-mono" style="color: var(--primary); display: flex; align-items: center; gap: 10px;">
                    <span style="font-size: 1.5rem;">🔒</span> Zero-Trust Architecture
                </h3>
                <p style="font-size: 0.9rem; margin-top: 1rem;">Absolute volatility. Room data exists only in active
                    memory and undergoes automatic self-destruction upon termination.</p>

                <div
                    style="display: flex; justify-content: space-around; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(16, 185, 129, 0.2);">
                    <div style="text-align: center;">
                        <div class="font-mono" style="font-size: 1.8rem; color: white;"><%= active_rooms %></div>
                        <div class="font-mono" style="font-size: 0.7rem; color: var(--text-muted);">ACTIVE ENVIRONMENTS
                        </div>
                    </div>
                    <div style="text-align: center;">
                        <div class="font-mono" style="font-size: 1.8rem; color: var(--secondary);">0 B</div>
                        <div class="font-mono" style="font-size: 0.7rem; color: var(--text-muted);">PERSISTENT STORAGE
                        </div>
                    </div>
                    <div style="text-align: center;">
                        <div class="font-mono" style="font-size: 1.8rem; color: var(--danger);">0</div>
                        <div class="font-mono" style="font-size: 0.7rem; color: var(--text-muted);">TELEMETRY LOGS</div>
                    </div>
                </div>
            </div>

            <!-- Professional Section -->
            <div class="card--border-glow col-span-2">
                <h3 class="font-mono" style="color: var(--text-main); display: flex; align-items: center; gap: 10px;">
                    <span>💼</span> Enterprise Protocol
                </h3>
                <p style="font-size: 0.85rem; margin: 1rem 0; color: var(--text-muted);">
                    Engineered for high-stakes communications where privacy is non-negotiable.
                </p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem;">
                    <div
                        style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
                        <div class="font-mono" style="color: var(--primary); font-size: 0.75rem; margin-bottom: 4px;">⚖️
                            LEGAL & LAW</div>
                    </div>
                    <div
                        style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
                        <div class="font-mono" style="color: var(--primary); font-size: 0.75rem; margin-bottom: 4px;">🏥
                            TELEMEDICINE</div>
                    </div>
                    <div
                        style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
                        <div class="font-mono" style="color: var(--primary); font-size: 0.75rem; margin-bottom: 4px;">🏢
                            ENTERPRISE</div>
                    </div>
                    <div
                        style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
                        <div class="font-mono" style="color: var(--primary); font-size: 0.75rem; margin-bottom: 4px;">
                            🛡️ JOURNALISM</div>
                    </div>
                </div>
                <div style="text-align: center;">
                    <a href="https://github.com/ArnavPundir22/BaatChit/blob/main/docs/architecture.md" target="_blank"
                        class="btn font-mono"
                        style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255,255,255,0.2); width: 100%; display: block; text-decoration: none; box-sizing: border-box;">Read
                        Architecture Docs ↗</a>
                </div>
            </div>

            <!-- Capabilities & Limits -->
            <div class="card--border-glow col-span-2">
                <h3 class="font-mono" style="color: var(--text-main); display: flex; align-items: center; gap: 10px;">
                    <span>⚡</span> Capabilities
                </h3>
                <p style="font-size: 0.85rem; margin: 1rem 0; color: var(--text-muted);">
                    Fully optimized for cross-platform usage with specific hardware boundaries.
                </p>
                <ul style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; padding-left: 1.2rem; margin-bottom: 1.5rem;">
                    <li><strong style="color: var(--primary);">Desktop Screen Sharing:</strong> Broadcast your screen in high definition from any desktop or laptop browser.</li>
                    <li><strong style="color: var(--primary);">Mobile Screen Viewing:</strong> Mobile users can perfectly view shared screens and participate via camera/microphone, though OS security prevents broadcasting the mobile screen itself.</li>
                    <li><strong style="color: var(--primary);">View-Once Media:</strong> Send ephemeral images that permanently self-destruct after a single view.</li>
                </ul>
            </div>

            <!-- App Promo -->
            <div class="card--border-glow col-span-4" style="text-align: center;">
                <h3 class="font-mono" style="color: var(--secondary); margin-bottom: 0.5rem;">[DEVICES] > Local
                    Installation</h3>
                <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto 1.5rem auto;">Mount BaatCheet
                    directly onto your hardware for an untethered, full-screen native experience.</p>

                <div id="install-instructions"
                    style="display: none; justify-content: center; gap: 2rem; flex-wrap: wrap;">
                    <div
                        style="background: rgba(0,0,0,0.3); padding: 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); flex: 1; min-width: 200px;">
                        <strong class="font-mono" style="color: var(--primary);">🍏 iOS (Safari)</strong><br><br>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Tap <b>Share</b> > <b>"Add to Home
                                Screen"</b></span>
                    </div>
                    <div
                        style="background: rgba(0,0,0,0.3); padding: 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); flex: 1; min-width: 200px;">
                        <strong class="font-mono" style="color: var(--primary);">🤖 Android</strong><br><br>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Browser menu > <b>"Add to Home
                                screen"</b></span>
                    </div>
                    <div
                        style="background: rgba(0,0,0,0.3); padding: 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); flex: 1; min-width: 200px;">
                        <strong class="font-mono" style="color: var(--primary);">💻 Desktop</strong><br><br>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Click the install icon in address
                            bar</span>
                    </div>
                </div>

                <button id="install-btn" class="btn btn-secondary font-mono"
                    style="display: none; margin: 0 auto; width: auto; min-width: 250px; text-transform: uppercase;">Execute
                    Install</button>
            </div>
        </div>

        <div style="text-align: center; margin-top: 3rem; margin-bottom: 2rem;">
            <a href="/about" class="font-mono"
                style="color: var(--text-muted); text-decoration: none; border-bottom: 1px dashed var(--text-muted); transition: color 0.3s ease;"
                onmouseover="this.style.color='var(--primary)'; this.style.borderColor='var(--primary)';"
                onmouseout="this.style.color='var(--text-muted)'; this.style.borderColor='var(--text-muted)';">About
                Platform</a>
            <span style="color: var(--text-muted); margin: 0 1rem;">|</span>
            <a href="https://github.com/ArnavPundir22/BaatChit" target="_blank" class="font-mono"
                style="color: var(--text-muted); text-decoration: none; border-bottom: 1px dashed var(--text-muted); transition: color 0.3s ease;"
                onmouseover="this.style.color='var(--primary)'; this.style.borderColor='var(--primary)';"
                onmouseout="this.style.color='var(--text-muted)'; this.style.borderColor='var(--text-muted)';">GitHub
                Source</a>
        </div>
    </div>
    <script>
        // Force unregister service workers to fix cache issues
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(function(registrations) {
                for(let registration of registrations) {
                    registration.unregister();
                }
            });
        }

        // PWA Install Logic
        document.addEventListener('DOMContentLoaded', () => {
            const isIos = () => {
                const userAgent = window.navigator.userAgent.toLowerCase();
                return /iphone|ipad|ipod/.test(userAgent);
            };

            // Detect if already installed
            const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
            const installCard = document.querySelector('.app-promo-card');
            const installInstructions = document.getElementById('install-instructions');

            if (isStandalone) {
                if (installCard) installCard.style.display = 'none';
            } else {
                // Show manual instructions always as fallback
                installInstructions.style.display = 'block';
            }
        });

        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            const installBtn = document.getElementById('install-btn');
            if (installBtn) {
                installBtn.style.display = 'block';
                installBtn.addEventListener('click', async () => {
                    if (deferredPrompt) {
                        deferredPrompt.prompt();
                        const { outcome } = await deferredPrompt.userChoice;
                        if (outcome === 'accepted') {
                            deferredPrompt = null;
                            installBtn.style.display = 'none';
                        }
                    }
                });
            }
        });
    </script>
    <!-- Cinematic Three.js Logic -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <script src="/static/js/cinematic-intro.js"></script>
    <script src="/static/js/home-3d-bg.js"></script>
</body>

</html>